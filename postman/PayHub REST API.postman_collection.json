        {
          "name": "List payment methods",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Contract tests - PayHub REST API: GET /payment-methods\r",
                  "\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", () => {\r",
                  "  pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is an array\", () => {\r",
                  "  const data = pm.response.json();\r",
                  "  pm.expect(Array.isArray(data)).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each item contains required fields\", () => {\r",
                  "  const data = pm.response.json();\r",
                  "  pm.expect(data.length).to.be.greaterThan(0);\r",
                  "\r",
                  "  data.forEach(item => {\r",
                  "    pm.expect(item).to.have.property(\"id\");\r",
                  "    pm.expect(item).to.have.property(\"method_type\");\r",
                  "    pm.expect(item).to.have.property(\"last_four\");\r",
                  "    pm.expect(item).to.have.property(\"expiry_date\");\r",
                  "  });\r",
                  "});\r",
                  "\r",
                  "// Optional: lightweight format checks (keep simple for interviews)\r",
                  "pm.test(\"last_four is 4 digits when present\", () => {\r",
                  "  const data = pm.response.json();\r",
                  "  data.forEach(item => {\r",
                  "    if (item.last_four) {\r",
                  "      pm.expect(String(item.last_four)).to.match(/^\\d{4}$/);\r",
                  "    }\r",
                  "  });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
